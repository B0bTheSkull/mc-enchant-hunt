    "modmenu": ["com.b0btheskull.enchanthunt.EnchantHuntModMenu"]
  },
  "depends": {
    "fabricloader": ">=0.19.0",
    "minecraft": ">=26.2-",
    "fabric-api": "*",
    "trade_cycling": "*",
    "cloth-config": "*",
    "modmenu": "*"
  }
}
